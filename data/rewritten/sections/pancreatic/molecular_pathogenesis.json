{
  "sections": [
    {
      "heading": "Molecular Pathogenesis Overview",
      "content": "The molecular pathogenesis of pancreatic adenocarcinoma involves a stepwise accumulation of genetic and epigenetic alterations."
    },
    {
      "heading": "KRAS and RAS-MAPK Pathway",
      "content": "The most common driver mutation is in the KRAS oncogene (present in >90% of cases), leading to constitutive activation of the RAS-MAPK signaling pathway, which promotes cell proliferation and survival."
    },
    {
      "heading": "Tumor Suppressor Genes",
      "content": "Inactivating mutations in tumor suppressor genes are also frequent: TP53 (>75% of cases), SMAD4 (DPC4, ~55%), and CDKN2A/p16 (~90% via deletion, mutation, or promoter methylation)."
    },
    {
      "heading": "TGF-β/SMAD Pathway",
      "content": "The TGF-β/SMAD pathway is disrupted by SMAD4 loss, altering growth control and immune evasion."
    },
    {
      "heading": "Chromatin Remodeling Genes",
      "content": "Other recurrently mutated genes include ARID1A, TGFBR2, and chromatin remodeling genes (e.g., MLL, MLL3, KMT2C)."
    },
    {
      "heading": "Homologous Recombination Repair and PARP Inhibitors",
      "content": "Homologous recombination repair genes, such as BRCA1, BRCA2, and PALB2, are mutated in approximately 5-7% of pancreatic adenocarcinomas, leading to genomic instability and sensitivity to platinum-based chemotherapies and PARP inhibitors."
    },
    {
      "heading": "MSI/dMMR and Immune Checkpoint Inhibitors",
      "content": "Microsatellite instability (MSI) and mismatch repair deficiency (dMMR) occur in <2% of cases but are therapeutically relevant due to responsiveness to immune checkpoint inhibitors."
    },
    {
      "heading": "Other Actionable Alterations and NGS",
      "content": "Other actionable molecular alterations include NTRK gene fusions (<1%), BRAF V600E mutations (~1-2%), HER2 amplification (<5%), and RET fusions (<1%). These are identified via next-generation sequencing (NGS) and guide targeted therapy."
    },
    {
      "heading": "Tumor Mutational Burden and Immunotherapy",
      "content": "Tumor mutational burden (TMB) is also assessed to predict immunotherapy response."
    },
    {
      "heading": "Tumor Microenvironment and Chemoresistance",
      "content": "The tumor microenvironment is characterized by a dense desmoplastic stroma, immunosuppressive cells, and hypovascularity, which contribute to chemoresistance."
    }
  ],
